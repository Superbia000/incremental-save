+(function installImageProxyInterceptor() {
+    const descriptor = Object.getOwnPropertyDescriptor(HTMLImageElement.prototype, 'src');
+    if (!descriptor || !descriptor.set) return;
+    const originalSet = descriptor.set;
+    const origin = window.location.origin;
+    Object.defineProperty(HTMLImageElement.prototype, 'src', {
+        ...descriptor,
+        set(value) {
+            if (typeof value === 'string' && (value.indexOf('://') > 0 || value.indexOf('//') === 0) && !value.startsWith(origin) && !value.startsWith('/api/image-proxy')) {
+                value = '/api/image-proxy?url=' + encodeURIComponent(value);
+            }
+            originalSet.call(this, value);
+        },
+    });
+    console.debug('[ImageProxy] Image.src interceptor installed');
+})();
+
