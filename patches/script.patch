+function computeChatHash(chatArray, upToIndex) {
+    let hash = '';
+    for (let i = 1; i < upToIndex && i < chatArray.length; i++) {
+        const m = chatArray[i];
+        hash += `${(m.mes || '').length}:${m.swipe_id ?? 0},`;
+    }
+    return hash;
+}
+
+function hasOldMessagesChanged(chatArray, savedLength) {
+    return computeChatHash(chatArray, savedLength) !== lastSavedChatHash;
+}
