+router.post('/save-append', validateAvatarUrlMiddleware, async function (request, response) {
+    try {
+        const handle = request.user.profile.handle;
+        const cardName = String(request.body.avatar_url).replace('.png', '');
+        const chatFileName = `${String(request.body.file_name)}.jsonl`;
+        const chatFilePath = path.join(request.user.directories.chats, cardName, sanitize(chatFileName));
+        const { header, newMessages, expectedLines } = request.body;
+
+        if (!Array.isArray(newMessages)) {
+            return response.status(400).send({ error: 'newMessages must be an array.' });
+        }
+
+        const result = await tryAppendChat(chatFilePath, header, newMessages, expectedLines, handle, cardName, request.user.directories.backups);
+
+        if (result.ok) {
+            return response.send({ ok: true });
+        } else if (result.error === 'line_mismatch') {
+            return response.status(409).send({ error: 'line_mismatch', actualLines: result.actualLines });
+        } else {
+            return response.status(400).send({ error: result.error });
+        }
+    } catch (error) {
+        console.error('Incremental save error:', error);
+        return response.status(500).send({ error: 'An error has occurred during incremental save.' });
+    }
+});
